# ── Bolt.new auto-injects these when you connect Supabase ─────────────────────
# (You do NOT need to set these manually — Bolt.new fills them in for you)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── You MUST add these manually in Bolt.new's environment variable panel ──────

# Your Tradier PRODUCTION API key (tradier.com → API Access)
# The server reads this — it is NEVER sent to the browser.
TRADIER_API_KEY=your_tradier_production_api_key

# Start recording automatically when the server boots (no browser needed)
AUTO_RECORD=true

# ── Optional overrides (Bolt.new defaults work fine without these) ─────────────

# How often to record in minutes. Default: 5
RECORD_INTERVAL_MINUTES=5

# How many SPX expirations to fetch per snapshot. Default: 20
MAX_EXPIRATIONS=20

# If you want server-side writes to bypass RLS (more secure than anon key):
# get this from Supabase dashboard → Project Settings → API → service_role key
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
